{
  "name": "@agentx/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "node scripts/generate-migration-registry.mjs",
    "build": "tsup && node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync('dist/data',{recursive:true});fs.copyFileSync('data/crew-catalog.manifest.json','dist/data/crew-catalog.manifest.json');fs.mkdirSync('dist/voice',{recursive:true});fs.copyFileSync(path.join('..','voice-sidecar','voice-models.manifest.json'),'dist/voice/voice-models.manifest.json')\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentx/shared": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/azure": "^3.0.74",
    "@ai-sdk/cohere": "^3.0.38",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/groq": "^3.0.41",
    "@ai-sdk/mistral": "^3.0.39",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@ai-sdk/perplexity": "^3.0.35",
    "@ai-sdk/xai": "^3.0.95",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "@slack/bolt": "^4.7.3",
    "ai": "^6.0.205",
    "discord.js": "^14.26.4",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "imap": "^0.8.19",
    "mailparser": "^3.9.9",
    "nodemailer": "^6.10.1",
    "openai": "^4.50.0",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.21.0",
    "pg-boss": "^10.1.5",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/imap": "^0.8.42",
    "@types/mailparser": "^3.4.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.12",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "redis": "^6.1.0"
  }
}
