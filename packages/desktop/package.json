{
  "name": "@agentx/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-X - AI-powered terminal agent",
  "author": "SlashpanOrg <hello@slashpan.com>",
  "main": "./dist/main.js",
  "scripts": {
    "build": "node scripts/generate-icon.mjs && tsup && node scripts/copy-xterm.mjs",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist renderer/xterm",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.agentx.desktop",
    "productName": "Agent-X",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../cli/dist",
        "to": "cli",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "build/icon.png",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "SlashpanOrg",
      "repo": "agent-x"
    }
  },
  "dependencies": {
    "electron-updater": "^6.0.0",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
