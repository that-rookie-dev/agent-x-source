{
  "name": "@agentx/desktop",
  "version": "0.8.2",
  "private": true,
  "description": "Agent-X — Your AI Wingman (Desktop)",
  "homepage": "https://github.com/SlashpanOrg/agent-x",
  "author": "SlashpanOrg <hello@slashpan.com>",
  "main": "./dist/main.js",
  "scripts": {
    "prebuild": "node ../../scripts/sync-version.mjs && node scripts/generate-icon.mjs",
    "setup:pgvector": "node scripts/setup-pgvector.mjs",
    "setup:age": "node scripts/setup-age.mjs",
    "setup:extensions": "node scripts/setup-pgvector.mjs && node scripts/setup-age.mjs",
    "build": "tsup",
    "build:deps": "pnpm --filter @agentx/web-api run build && pnpm --filter @agentx/web-ui run build",
    "dev": "tsup && electron dist/main.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "npm run build && electron-builder --mac && node scripts/bundle-pg-deps.mjs",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.agentx.desktop",
    "productName": "Agent-X",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "afterPack": "scripts/afterpack.cjs",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@embedded-postgres/**/*",
      "node_modules/embedded-postgres/**/*"
    ],
    "extraResources": [
      {
        "from": "../web-api/dist",
        "to": "web-api",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web-ui/dist",
        "to": "web-ui",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web-neuron/dist",
        "to": "web-neuron",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build",
        "to": "build",
        "filter": [
          "*.png",
          "*.plist"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "icon": "build/icon.icns",
      "iconSize": 128,
      "title": "Agent-X ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "deb": {
      "packageName": "agentx",
      "artifactName": "agentx_${version}_${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "SlashpanOrg",
      "repo": "agent-x"
    }
  },
  "dependencies": {
    "electron-updater": "^6.0.0",
    "embedded-postgres": "17.5.0-beta.15",
    "@embedded-postgres/darwin-arm64": "17.5.0-beta.15",
    "@embedded-postgres/darwin-x64": "17.5.0-beta.15",
    "@embedded-postgres/linux-arm64": "17.5.0-beta.15",
    "@embedded-postgres/linux-x64": "17.5.0-beta.15",
    "@embedded-postgres/windows-x64": "17.5.0-beta.15",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/pg": "^8.20.0",
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
