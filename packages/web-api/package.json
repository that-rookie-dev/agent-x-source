{
  "name": "@agentx/web-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup && node -e \"require('fs').mkdirSync('dist/data',{recursive:true});require('fs').copyFileSync('../engine/data/crew-catalog.manifest.json','dist/data/crew-catalog.manifest.json')\" && node scripts/copy-runtime-deps.js",
    "bundle-models": "node scripts/bundle-embedding-model.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:server": "node scripts/start.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentx/engine": "workspace:*",
    "@agentx/shared": "workspace:*",
    "@huggingface/transformers": "^3.8.1",
    "ai": "^6.0.205",
    "cron-parser": "^4.9.0",
    "express": "^4.21.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "pg-boss": "^10.1.5",
    "pg-connection-string": "^2.13.0",
    "pg-pool": "^3.14.0",
    "pg-protocol": "^1.14.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.12",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "optionalDependencies": {
    "electron": "^30.0.0"
  }
}
