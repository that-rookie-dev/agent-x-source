{
  "name": "agent-x",
  "version": "0.9.10",
  "private": true,
  "type": "module",
  "description": "Agent-X — Your AI Wingman",
  "scripts": {
    "prebuild": "vitest run --run packages/engine/tests/platform-parity.test.ts",
    "build": "pnpm run setup:env && pnpm -r run build",
    "dev": "pnpm run setup:env && pnpm --filter @agentx/web-api run dev",
    "test": "vitest run",
    "prestart": "vitest run --run packages/engine/tests/platform-parity.test.ts",
    "check:platform": "vitest run --run packages/engine/tests/platform-parity.test.ts",
    "verify:integrations": "vitest run --run packages/engine/tests/integrations.test.ts packages/engine/tests/integrations-e2e.test.ts",
    "verify:integrations-catalog": "tsx scripts/verify-integrations-catalog.mjs",
    "test:watch": "vitest",
    "lint": "eslint packages/engine/src packages/shared/src packages/web-api/src",
    "typecheck": "pnpm -r run typecheck",
    "dev:web-api": "pnpm --filter @agentx/web-api run dev",
    "dev:desktop": "bash scripts/dev-desktop.sh",
    "dev:desktop:sync": "bash scripts/sync-desktop.sh",
    "build:web-api": "pnpm --filter @agentx/web-api run build",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "setup:env": "node -e \"const fs=require('fs'); if(!fs.existsSync('.env')){ fs.writeFileSync('.env', fs.readFileSync('.env.example','utf8')); console.log('Created .env from .env.example'); } else { console.log('.env already exists'); }\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "4.19.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "prismjs@<1.30.0": ">=1.30.0",
      "electron@<35.7.5": ">=35.7.5",
      "nodemailer@<7.0.7": ">=7.0.7",
      "tar@<7.5.7": ">=7.5.7",
      "semver@>=2.0.0-alpha <5.7.2": ">=5.7.2",
      "nodemailer@<=7.0.10": ">=7.0.11",
      "tar@<=7.5.2": ">=7.5.3",
      "tar@<7.5.8": ">=7.5.8",
      "tar@<=7.5.9": ">=7.5.10",
      "tar@<=7.5.10": ">=7.5.11",
      "tar@<=7.5.3": ">=7.5.4",
      "nodemailer@<8.0.4": ">=8.0.4",
      "electron@<38.8.6": ">=38.8.6",
      "electron@<39.8.1": ">=39.8.1",
      "electron@>=33.0.0-alpha.1 <39.8.5": ">=39.8.5",
      "vite@<=6.4.1": ">=6.4.2",
      "electron@<39.8.5": ">=39.8.5",
      "nodemailer@<=8.0.4": ">=8.0.5",
      "vitest@<4.1.0": ">=4.1.0"
    },
    "patchedDependencies": {}
  }
}
