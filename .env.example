# Agent-X environment template
# This file lives inside the source folder and is safe to commit as an example.
# Copy it to `.env` and fill in real values when running outside the desktop app.

# Embedded PostgreSQL (default when running the Agent-X desktop app).
# The desktop app starts its own PostgreSQL on port 3335 and sets this automatically.
AGENTX_POSTGRES_CONNECTION_STRING=postgresql://agentx:agentx@127.0.0.1:3335/agentx

# Optional: override the web-api port
# AGENTX_PORT=3333
