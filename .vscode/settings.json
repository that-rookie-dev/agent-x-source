{
  "typescript.tsdk": "node_modules/typescript/lib",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.exclude": {
    "**/dist": false,
    "**/out": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/dist": true,
    "**/out": true,
    "**/node_modules": true
  },
  "eslint.workingDirectories": [
    ".",
    "packages/cli",
    "packages/engine",
    "packages/shared",
    "packages/tui",
    "packages/web-api",
    "packages/vscode"
  ]
}
