{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:vscode",
      "type": "npm",
      "script": "build",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode"
      },
      "group": "build",
      "problemMatcher": ["$esbuild-watch"],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "watch:vscode",
      "type": "npm",
      "script": "watch",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$esbuild-watch"],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "watch:vscode:webview",
      "type": "npm",
      "script": "watch:webview",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode"
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$esbuild-watch"],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "build:vscode:tests",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json --outDir out",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode"
      },
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "typecheck:vscode",
      "type": "npm",
      "script": "typecheck",
      "options": {
        "cwd": "${workspaceFolder}/packages/vscode"
      },
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
